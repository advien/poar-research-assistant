# =============================================================================
# Cross-platform line-ending policy.
# Repo content is always LF; working copies on Windows can render with CRLF.
# This keeps diffs clean across macOS / Linux / Windows contributors.
# =============================================================================

# Default: detect text files automatically, normalise to LF in the repo.
* text=auto eol=lf

# Windows-only scripts must keep CRLF on disk to be runnable.
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary types - never convert.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary
*.7z        binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary

# Lockfiles - always LF, no diff drama on cross-platform installs.
package-lock.json   text eol=lf
yarn.lock           text eol=lf
pnpm-lock.yaml      text eol=lf

# Mark these as having reasonable diff treatment / linguist hints.
*.md        text diff=markdown
*.tsx       text diff=typescript
*.ts        text diff=typescript

# GitHub linguist: don't count generated/vendored files toward repo language stats.
docs/**           linguist-documentation
supabase/migrations/*.sql  linguist-vendored=false
