# =============================================================================
# POAR Research Assistant - environment template
# Copy to `.env.local` for development or set in your hosting provider for prod.
# Never commit a filled `.env*` file.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Project URL and anon key are public and safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key is SERVER-ONLY. Used by the ingestion pipeline to insert
# chunks under RLS bypass. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# AI providers (required)
# -----------------------------------------------------------------------------
# Anthropic Claude is used for chat, summaries, terminology, and comparisons.
ANTHROPIC_API_KEY=

# OpenAI is used only for embeddings (text-embedding-3-small).
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# App configuration
# -----------------------------------------------------------------------------
# Public canonical origin. Used to build magic-link redirect URLs.
# Local dev:   http://localhost:3000
# Production:  https://research.advien.tech
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Rate limiting (optional - defaults are sane)
# -----------------------------------------------------------------------------
# Per-user (or per-IP for anonymous) rate limits, expressed as max requests
# per 60-second window. Each scope has its own bucket so a slow comparison
# does not eat the chat budget. Override per environment as needed.
#
# RATE_LIMIT_CHAT_PER_MIN=10
# RATE_LIMIT_UPLOAD_PER_MIN=3
# RATE_LIMIT_INGEST_PER_MIN=3
# RATE_LIMIT_SUMMARY_PER_MIN=5
# RATE_LIMIT_TERMINOLOGY_PER_MIN=5
# RATE_LIMIT_COMPARISON_PER_MIN=3
# RATE_LIMIT_SEARCH_PER_MIN=30

# -----------------------------------------------------------------------------
# Ingestion / answer bounds (optional - defaults are sane)
# -----------------------------------------------------------------------------
# Hard cap on uploaded file size in bytes. Default 25 MiB.
# UPLOAD_MAX_BYTES=26214400
#
# Hard cap on PDF page count. Documents with more pages are rejected before
# the embedding budget is spent. Default 200.
# INGEST_MAX_PAGES=200
#
# Per-answer output-token cap on /api/chat. Bounds cost + protects against
# prompt injections that try to elicit unbounded responses. Default 2048.
# CHAT_MAX_OUTPUT_TOKENS=2048

# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------
# Minimum level to emit. One of: debug | info | warn | error. Default: info.
# LOG_LEVEL=info
